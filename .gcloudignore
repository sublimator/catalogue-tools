# Use .gitignore rules as base
#!include:.gitignore

# Include .git for rev-parse, but exclude the heavy parts (blobs, lfs)
!.git/
.git/objects/**
.git/lfs/**
.ai-docs/
.claude/
.specstory/
.idea/
.mypy_cache/
__pycache__/
node_modules/
catenv/
test-nudb/
asio-patterns/
tests/
build/
build-*/
build-hbb/
debug.txt
server-logs.txt
peermon.log
test-decompressed.catl
proof-*.json
proof-*.bin
.mcp.json
*.bin
*.o
*.a
*.catl
*.catl2
*.zstd
*.zst
